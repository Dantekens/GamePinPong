#include <ncurses.h>
#include <stdio.h>
#include <unistd.h>

#define ROWS 25
#define COLS 80
#define DEFAULT_DELAY 200000
#define MIN_DELAY 20000
#define MAX_DELAY 1000000

int read_init_state(int grid[ROWS][COLS]);
void render(int grid[ROWS][COLS]);
int count_neighbors(int grid[ROWS][COLS], int r, int c);
void update_grid(int current[ROWS][COLS], int next[ROWS][COLS]);
void copy_grid(int current[ROWS][COLS], int next[ROWS][COLS]);

int main() {
    int current_grid[ROWS][COLS];
    int next_grid[ROWS][COLS];
    int delay = DEFAULT_DELAY;
    int run = 1;
    int is_paused = 0;
    int exit_code = 0;

    // 1. Читаем из файла через стандартный scanf ДО старта ncurses
    if (!read_init_state(current_grid)) {
        fprintf(stderr, "Error: Invalid initial state data.\n");
        exit_code = 1;
        run = 0;
    }

    // 2. Возвращаем stdin на клавиатуру, чтобы ncurses слушал кнопки
    if (run && freopen("/dev/tty", "r", stdin) == NULL) {
        fprintf(stderr, "Error: Failed to redirect stdin to terminal.\n");
        exit_code = 1;
        run = 0;
    }

    if (run) {
        initscr();
        cbreak();
        noecho();
        nodelay(stdscr, TRUE);
        curs_set(0);
    }

    while (run) {
        render(current_grid);
        if (!is_paused) {
            update_grid(current_grid, next_grid);
            copy_grid(current_grid, next_grid);
        }
        int ch = getch();
        if (ch == 'q' || ch == 'Q') {
            run = 0;
        } else if (ch == ' ') {
            is_paused = !is_paused;
        } else if ((ch == 'a' || ch == 'A') && delay > MIN_DELAY) {
            delay -= 20000;
        } else if ((ch == 'z' || ch == 'Z') && delay < MAX_DELAY) {
            delay += 20000;
        }
        usleep(delay);
    }

    if (exit_code == 0) {
        mvprintw(ROWS, 0, "Game over. Press ANY KEY to exit...");
        refresh();
        nodelay(stdscr, FALSE);
        getch();
        endwin();
    }
    return exit_code;
}

int read_init_state(int grid[ROWS][COLS]) {
    int success = 1;
    for (int i = 0; i < ROWS; i++) {
        for (int j = 0; j < COLS; j++) {
            if (scanf("%d", &grid[i][j]) != 1) {
                success = 0;
            }
        }
    }
    return success;
}

void render(int grid[ROWS][COLS]) {
    clear();
    for (int i = 0; i < ROWS; i++) {
        for (int j = 0; j < COLS; j++) {
            if (grid[i][j] == 1) {
                mvaddch(i, j, '#');
            } else {
                mvaddch(i, j, ' ');
            }
        }
    }
    refresh();
}

int count_neighbors(int grid[ROWS][COLS], int r, int c) {
    int count = 0;
    for (int i = -1; i <= 1; i++) {
        for (int j = -1; j <= 1; j++) {
            if (i != 0 || j != 0) {
                int neighbor_r = (r + i + ROWS) % ROWS;
                int neighbor_c = (c + j + COLS) % COLS;
                if (grid[neighbor_r][neighbor_c] == 1) {
                    count++;
                }
            }
        }
    }
    return count;
}

void update_grid(int current[ROWS][COLS], int next[ROWS][COLS]) {
    for (int i = 0; i < ROWS; i++) {
        for (int j = 0; j < COLS; j++) {
            int neighbors = count_neighbors(current, i, j);
            if (current[i][j] == 1) {
                if (neighbors < 2 || neighbors > 3) {
                    next[i][j] = 0;
                } else {
                    next[i][j] = 1;
                }
            } else {
                if (neighbors == 3) {
                    next[i][j] = 1;
                } else {
                    next[i][j] = 0;
                }
            }
        }
    }
}

void copy_grid(int current[ROWS][COLS], int next[ROWS][COLS]) {
    for (int i = 0; i < ROWS; i++) {
        for (int j = 0; j < COLS; j++) {
            current[i][j] = next[i][j];
        }
    }
}
